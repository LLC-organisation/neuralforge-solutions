# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/biashara_automation"

# Resend API key (https://resend.com)
RESEND_API_KEY="re_your_api_key"

# Email address to receive lead notifications
RESEND_TO_EMAIL="team@biashara-automation.com"
RESEND_FROM_EMAIL="noreply@biashara-automation.com"

# Admin auth (generate a strong random password and secret)
ADMIN_PASSWORD="change-me-to-a-strong-password"
SESSION_SECRET="change-me-to-a-32-char-random-secret"

# App URL (used for sitemap and Open Graph)
NEXT_PUBLIC_APP_URL="https://biashara-automation.com"
